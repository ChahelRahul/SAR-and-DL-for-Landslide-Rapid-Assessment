{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sar-lra.example/schemas/request.schema.json",
  "title": "SAR-LRA processing request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "roi",
    "temporal",
    "orbit"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "roi": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "geometry"
          ],
          "properties": {
            "type": {
              "const": "geojson"
            },
            "geometry": {
              "type": "object",
              "required": [
                "type",
                "coordinates"
              ],
              "properties": {
                "type": {
                  "enum": [
                    "Polygon",
                    "MultiPolygon"
                  ]
                },
                "coordinates": {
                  "type": "array",
                  "minItems": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "const": "file"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "layer": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "temporal": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "event_date"
          ],
          "properties": {
            "mode": {
              "const": "event_date"
            },
            "event_date": {
              "type": "string",
              "format": "date"
            },
            "pre_days": {
              "type": "integer",
              "minimum": 1,
              "default": 30
            },
            "post_days": {
              "type": "integer",
              "minimum": 1,
              "default": 30
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "pre_start",
            "pre_end",
            "post_start",
            "post_end"
          ],
          "properties": {
            "mode": {
              "const": "explicit_ranges"
            },
            "pre_start": {
              "type": "string",
              "format": "date"
            },
            "pre_end": {
              "type": "string",
              "format": "date"
            },
            "post_start": {
              "type": "string",
              "format": "date"
            },
            "post_end": {
              "type": "string",
              "format": "date"
            }
          }
        }
      ]
    },
    "orbit": {
      "enum": [
        "ascending",
        "descending",
        "both"
      ]
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "directory": {
          "type": "string",
          "default": "/output"
        },
        "vector_format": {
          "enum": [
            "geojson",
            "gpkg"
          ],
          "default": "geojson"
        },
        "include_detection_mask": {
          "type": "boolean",
          "default": true
        },
        "include_probability_surface": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
